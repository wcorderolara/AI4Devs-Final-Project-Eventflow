# EventFlow Frontend — variables públicas (Doc 21 §9.3).
# Solo claves con prefijo NEXT_PUBLIC_*. Sin valores reales, sin secrets.
# Copia este archivo a `.env.local` (no versionado) y completa los valores locales.

# Base URL del backend REST (Doc 16). En deploy se configura en Amplify (Doc 21 §9.3).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# Entorno lógico de la app frontend: local | staging | production.
NEXT_PUBLIC_APP_ENV=local

# Site key pública del captcha (sin valor real en el repo).
NEXT_PUBLIC_CAPTCHA_SITE_KEY=

# i18n (US-104) — informativas/diagnóstico. La fuente de verdad en runtime es
# `src/shared/i18n/config.ts` (no estas env vars).
NEXT_PUBLIC_DEFAULT_LOCALE=es-LATAM
NEXT_PUBLIC_SUPPORTED_LOCALES=es-LATAM,es-ES,pt,en

# Routing / SEO (US-105) — base URL absoluta para robots.txt y sitemap.xml.
# En deploy se configura al dominio real (Amplify). Fallback runtime: http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Data layer (US-106) — MSW mocking. `enabled` activa el worker MSW en dev (backend simulado);
# cualquier otro valor / ausente → backend real. NUNCA se incluye en producción.
NEXT_PUBLIC_API_MOCKING=disabled
