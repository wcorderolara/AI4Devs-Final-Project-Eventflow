{
  "name": "eventflow-backend",
  "version": "0.0.0",
  "private": true,
  "description": "EventFlow backend — Bootstrap Node + Express + TypeScript (US-089) sobre Prisma schema (US-099).",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "node --loader ts-node/esm src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "test": "vitest run",
    "seed": "tsx src/scripts/seed.ts",
    "check:structure": "bash scripts/check-structure.sh",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:format": "prisma format",
    "db:check": "npm run db:validate && npm run db:generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:diff": "prisma migrate diff --from-migrations ./prisma/migrations --to-schema-datamodel ./prisma/schema.prisma --shadow-database-url \"${SHADOW_DATABASE_URL}\" --exit-code",
    "db:migrate:reset": "bash scripts/db-migrate-reset.sh",
    "openapi:generate": "tsx scripts/openapi-generate.ts",
    "openapi:lint": "tsx scripts/openapi-lint.ts",
    "openapi:check": "tsx scripts/openapi-check.ts",
    "openapi:docs": "tsx scripts/openapi-docs.ts",
    "promptops:hash": "tsx scripts/promptops-hash.ts",
    "promptops:check": "vitest run tests/unit/us121-",
    "test:us122": "vitest run tests/unit/us122- tests/integration/us122-",
    "test:us123": "vitest run tests/unit/us123-",
    "test:us124": "vitest run tests/unit/us124-"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "22.10.2",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "ajv": "^8.20.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import": "^2.31.0",
    "openapi-types": "^12.1.3",
    "prisma": "5.22.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
