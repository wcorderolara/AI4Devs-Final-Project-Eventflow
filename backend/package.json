{
  "name": "eventflow-backend",
  "version": "0.0.0",
  "private": true,
  "description": "EventFlow backend — Prisma schema declarativo (US-099).",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:format": "prisma format",
    "db:check": "npm run db:validate && npm run db:generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:diff": "prisma migrate diff --from-migrations ./prisma/migrations --to-schema-datamodel ./prisma/schema.prisma --shadow-database-url \"${SHADOW_DATABASE_URL}\" --exit-code",
    "db:migrate:reset": "bash scripts/db-migrate-reset.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "prisma": "5.22.0",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
