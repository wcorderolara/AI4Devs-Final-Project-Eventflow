// EventFlow — Schema Prisma declarativo por dominio MVP
// User Story: US-099 (PB-P0-001). Fuentes: Doc 6 (Domain Data Model), Doc 18 (Database Physical Design).
// Alcance: SOLO declaración estática + generación del Prisma Client.
//   - Migraciones ejecutables            -> US-100
//   - Índices funcionales/GIN/parciales  -> US-101
//   - Check constraints / unique parcial -> US-102
// Convenciones físicas: snake_case (@@map/@map), Decimal(14,2), Timestamptz(6), JsonB,
// isSeed en modelos operativos, deletedAt en los 7 modelos con soft delete (ADR-DB-004),
// UUID v4 PK en todas las tablas (ADR-DB-002), @relation explícito + onDelete Restrict por defecto.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums base (AC-02)
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  organizer
  vendor
  admin
}

// US-094 (PB-P0-004): estado de cuenta de usuario. `active` por defecto; `suspended` reservado
// para bloqueo administrativo (fuera de scope de registro público). Doc 19 §Auth.
enum UserStatus {
  active
  suspended
}

enum CurrencyCode {
  GTQ
  EUR
  MXN
  COP
  USD
}

enum LanguageCode {
  es_LATAM @map("es-LATAM")
  es_ES    @map("es-ES")
  pt
  en
}

enum LLMProvider {
  openai
  mock
  anthropic
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums de status por entidad (AC-02) — máquinas de estado separadas, sin enum genérico
// Valores canónicos: Doc 18 §"Catálogo de Enums".
// ─────────────────────────────────────────────────────────────────────────────

enum EventStatus {
  draft
  active
  completed
  cancelled
}

enum EventTaskStatus {
  pending
  // US-031 (PB-P1-017): estado intermedio para bulk confirm HITL (`pending → active`).
  active
  in_progress
  done
  skipped
}

enum EventTaskOrigin {
  manual
  ai
}

enum QuoteRequestStatus {
  sent
  viewed
  responded
  expired
  cancelled
}

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
}

enum BookingIntentStatus {
  pending
  confirmed_intent
  cancelled
}

enum ReviewStatus {
  published
  hidden
  removed
}

enum NotificationStatus {
  unread
  read
}

enum AttachmentStatus {
  active
  deleted
}

enum VendorProfileStatus {
  pending
  approved
  rejected
  hidden
}

enum VendorServiceStatus {
  active
  inactive
}

// Incluye `edited` requerido por el flujo HITL (US-099 §AI Behavior) además de los
// valores de Doc 18 (pending, accepted, rejected, discarded, failed, expired).
enum AIRecommendationStatus {
  pending
  accepted
  edited
  rejected
  discarded
  failed
  expired
}

// US-102: estado de versión de prompt (una activa por prompt_id — Doc 18 §21.2).
enum AIPromptVersionStatus {
  active
  deprecated
}

// ─────────────────────────────────────────────────────────────────────────────
// Platform / Shared
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                String       @id @default(uuid()) @db.Uuid
  email             String       @unique
  passwordHash      String       @map("password_hash")
  fullName          String?      @map("full_name")
  // US-094 (PB-P0-004): teléfono opcional de perfil propio (editable por PATCH /users/me).
  phone             String?
  role              UserRole
  // US-094: estado de cuenta; registro público crea usuarios `active` (AC-01).
  status            UserStatus   @default(active)
  preferredLanguage LanguageCode @default(es_LATAM) @map("preferred_language")

  events              Event[]
  vendorProfile       VendorProfile?
  reviews             Review[]
  notifications       Notification[]
  adminActions        AdminAction[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  aiRecommendations   AIRecommendation[]
  // US-028/029/031 (PB-P1-017/018): relaciones inversas de auditoría de EventTask.
  eventTasksCreated   EventTask[]          @relation("EventTaskCreatedBy")
  eventTasksUpdated   EventTask[]          @relation("EventTaskUpdatedBy")
  eventTasksDeleted   EventTask[]          @relation("EventTaskDeletedBy")
  eventTasksConfirmed EventTask[]          @relation("EventTaskConfirmedBy")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean  @default(false) @map("is_seed")

  @@map("users")
}

// US-094 (PB-P0-004): sesión server-side para transporte por cookie HTTP-only firmada
// (ADR-SEC-002). El `id` (sid) opaco viaja firmado en la cookie; `revokedAt` habilita logout
// efectivo (AC-05: llamadas protegidas posteriores → 401). No almacena el valor de la cookie.
model Session {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// US-094 (PB-P0-004): token de reset de contraseña de un solo uso (AC-06/AC-07). Se almacena
// SOLO el hash SHA-256 del token (`tokenHash`), nunca el valor crudo (ADR-SEC-001, riesgo de
// account takeover). `consumedAt` marca uso; `expiresAt` aplica TTL (15 min, EC-06).
model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Location {
  id      String  @id @default(uuid()) @db.Uuid
  country String
  region  String?
  city    String?
  lat     Float?
  lng     Float?

  events         Event[]
  vendorProfiles VendorProfile[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean   @default(false) @map("is_seed")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("locations")
}

model ServiceCategory {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  label       String
  description String?
  isActive    Boolean @default(true) @map("is_active")
  // US-102: soporte para chk_service_categories_depth_level (C-026b; BETWEEN 1 AND 2).
  depthLevel  Int     @default(1) @map("depth_level")

  vendorServices VendorService[]
  quoteRequests  QuoteRequest[]
  bookingIntents BookingIntent[]
  // US-027 (PB-P1-018): relación inversa débil con `event_tasks.category_code`.
  eventTasks     EventTask[]     @relation("EventTaskServiceCategory")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean   @default(false) @map("is_seed")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("service_categories")
}

model EventType {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  label       String
  description String?
  isActive    Boolean @default(true) @map("is_active")

  events Event[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean   @default(false) @map("is_seed")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("event_types")
}

// ─────────────────────────────────────────────────────────────────────────────
// Vendor
// ─────────────────────────────────────────────────────────────────────────────

model VendorProfile {
  id                  String              @id @default(uuid()) @db.Uuid
  userId              String              @map("user_id") @db.Uuid
  businessName        String              @map("business_name")
  bio                 String?
  status              VendorProfileStatus @default(pending)
  locationId          String?             @map("location_id") @db.Uuid
  // US-102: soporte para chk_vendor_profiles_category_change_max (C-022b; <= 5)
  // y chk_vendor_profiles_languages_not_empty (Doc 18 §15.1; cardinality > 0).
  categoryChangeCount Int                 @default(0) @map("category_change_count")
  languagesSupported  String[]            @map("languages_supported")

  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  location Location? @relation(fields: [locationId], references: [id], onDelete: Restrict)

  services          VendorService[]
  quotes            Quote[]
  reviews           Review[]
  quoteRequests     QuoteRequest[]
  bookingIntents    BookingIntent[]
  aiRecommendations AIRecommendation[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean   @default(false) @map("is_seed")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@unique([userId])
  @@index([locationId])
  @@map("vendor_profiles")
}

model VendorService {
  id                String              @id @default(uuid()) @db.Uuid
  vendorProfileId   String              @map("vendor_profile_id") @db.Uuid
  serviceCategoryId String              @map("service_category_id") @db.Uuid
  title             String
  description       String?
  status            VendorServiceStatus @default(active)
  // is_active: flag booleano de disponibilidad para índice parcial idx_vendor_services_active (US-101 / Doc 18 §25).
  isActive          Boolean             @default(true) @map("is_active")
  priceMin          Decimal?            @map("price_min") @db.Decimal(14, 2)
  priceMax          Decimal?            @map("price_max") @db.Decimal(14, 2)

  vendorProfile   VendorProfile   @relation(fields: [vendorProfileId], references: [id], onDelete: Restrict)
  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Restrict)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean   @default(false) @map("is_seed")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([vendorProfileId])
  @@index([serviceCategoryId])
  @@map("vendor_services")
}

// Attachment polimórfico: owner_type + owner_id (Doc 18 §19). Sin FK formal;
// la consistencia del owner se valida en la capa de aplicación (constraint funcional -> US-102).
model Attachment {
  id        String           @id @default(uuid()) @db.Uuid
  ownerType String           @map("owner_type")
  ownerId   String           @map("owner_id") @db.Uuid
  status    AttachmentStatus @default(active)
  url       String
  fileName  String?          @map("file_name")
  mimeType  String?          @map("mime_type")
  // work_label: agrupador de galería de trabajos del vendor para índice parcial
  // idx_attachments_vendor_work_active (US-101 / Doc 18 §25; límite 10 imágenes C-022).
  workLabel String?          @map("work_label")
  // US-102: soporte para chk_attachments_size_bytes_nonneg (Doc 18 §19.1; >= 0). NULL permitido.
  sizeBytes Int?             @map("size_bytes")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean   @default(false) @map("is_seed")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([ownerType, ownerId])
  @@map("attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Event
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  eventTypeId     String       @map("event_type_id") @db.Uuid
  locationId      String?      @map("location_id") @db.Uuid
  title           String
  status          EventStatus  @default(draft)
  currency        CurrencyCode @default(GTQ)
  language        LanguageCode @default(es_LATAM)
  eventDate       DateTime?    @map("event_date") @db.Timestamptz(6)
  // US-102: soporte para chk_events_guests_count_positive (C-009) y chk_events_estimated_budget_nonneg (C-010).
  guestsCount     Int?         @map("guests_count")
  estimatedBudget Decimal?     @map("estimated_budget") @db.Decimal(14, 2)
  // US-095 (PB-P0-004): notas libres opcionales del evento (no se loguean completas — SEC-08).
  notes           String?
  // US-095: compatibilidad con el job de auto-completion T+2 (PB-P1-009). En US-095 siempre `false`
  // en creación; el cierre automático pertenece a la historia del job. `completedAt` se poblará
  // al completar el evento (fuera de scope de US-095, pero el schema/DTO deben soportarlo).
  autoCompleted   Boolean      @default(false) @map("auto_completed")
  completedAt     DateTime?    @map("completed_at") @db.Timestamptz(6)

  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)
  location  Location? @relation(fields: [locationId], references: [id], onDelete: Restrict)

  tasks             EventTask[]
  budget            Budget?
  quoteRequests     QuoteRequest[]
  aiRecommendations AIRecommendation[]
  bookingIntents    BookingIntent[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean   @default(false) @map("is_seed")
  // US-012 (PB-P1-007): soft delete de eventos en `draft`. `deleted_at` marca la baja lógica;
  // `deleted_by` guarda el userId del organizador que la ejecutó (sin FK para evitar relación
  // inversa; BR-EVENT-010: nunca hard delete). Las lecturas owner-scoped filtran `deleted_at IS NULL`.
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  @@index([userId])
  @@index([eventTypeId])
  @@index([locationId])
  @@map("events")
}

model EventTask {
  id                 String          @id @default(uuid()) @db.Uuid
  eventId            String          @map("event_id") @db.Uuid
  title              String
  // US-027 (PB-P1-018): descripción opcional del ítem del checklist.
  description        String?
  dueDate            DateTime?       @map("due_date") @db.Timestamptz(6)
  status             EventTaskStatus @default(pending)
  origin             EventTaskOrigin @default(manual)
  // US-027 (PB-P1-018): categoría opcional (FK débil hacia `service_categories.code`).
  categoryCode       String?         @map("category_code")
  // US-031 (PB-P1-017): bandera aditiva alineada con Doc 18 §14.3. Marca tareas generadas por IA
  // aunque el `origin` sea `manual` (por ejemplo, ítem creado manualmente a partir de una sugerencia).
  aiGenerated        Boolean         @default(false) @map("ai_generated")
  aiRecommendationId String?         @map("ai_recommendation_id") @db.Uuid
  // US-031 (PB-P1-017): auditoría HITL. `confirmed_by_user_id` distinto de `created_by_user_id`
  // (US-028): éste último es el creador; `confirmed_by_user_id` sólo el que confirma bulk.
  confirmedByUserId  String?         @map("confirmed_by_user_id") @db.Uuid
  confirmedAt        DateTime?       @map("confirmed_at") @db.Timestamptz(6)
  // US-028 (PB-P1-018): idioma heredado del evento en el momento del insert (BR-AI-011).
  languageCode       LanguageCode?   @map("language_code")
  createdByUserId    String?         @map("created_by_user_id") @db.Uuid
  // US-029 (PB-P1-018 EMERGENT-001): auditoría de mutaciones.
  updatedByUserId    String?         @map("updated_by_user_id") @db.Uuid
  deletedByUserId    String?         @map("deleted_by_user_id") @db.Uuid
  // US-027 (PB-P1-018): soft delete lógico. Las lecturas owner-scoped filtran `deleted_at IS NULL`.
  deletedAt          DateTime?       @map("deleted_at") @db.Timestamptz(6)

  event            Event             @relation(fields: [eventId], references: [id], onDelete: Restrict)
  serviceCategory  ServiceCategory?  @relation("EventTaskServiceCategory", fields: [categoryCode], references: [code], onDelete: SetNull, onUpdate: Cascade)
  aiRecommendation AIRecommendation? @relation("EventTaskAIRecommendation", fields: [aiRecommendationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  confirmedByUser  User?             @relation("EventTaskConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdByUser    User?             @relation("EventTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedByUser    User?             @relation("EventTaskUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deletedByUser    User?             @relation("EventTaskDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean  @default(false) @map("is_seed")

  @@index([eventId])
  // US-027 (PB-P1-018): índice canónico de listado (event_id + status + due_date). Doc 18 §14.
  @@index([eventId, status, dueDate], map: "idx_event_tasks_event_status_due")
  // US-031 (PB-P1-017): índices para bulk confirm HITL (Doc 18 §14.3).
  @@index([eventId, aiGenerated, status])
  @@index([aiRecommendationId])
  @@map("event_tasks")
}

model Budget {
  id             String  @id @default(uuid()) @db.Uuid
  eventId        String  @unique @map("event_id") @db.Uuid
  totalPlanned   Decimal @default(0) @map("total_planned") @db.Decimal(14, 2)
  totalCommitted Decimal @default(0) @map("total_committed") @db.Decimal(14, 2)

  event Event        @relation(fields: [eventId], references: [id], onDelete: Restrict)
  items BudgetItem[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean  @default(false) @map("is_seed")

  @@map("budgets")
}

model BudgetItem {
  id              String  @id @default(uuid()) @db.Uuid
  budgetId        String  @map("budget_id") @db.Uuid
  label           String
  categoryCode    String? @map("category_code")
  amountPlanned   Decimal @default(0) @map("amount_planned") @db.Decimal(14, 2)
  amountCommitted Decimal @default(0) @map("amount_committed") @db.Decimal(14, 2)
  // US-037 (PB-P1-021): trazabilidad IA por fila (patrón EventTask.aiRecommendationId).
  // Nullable — items manuales lo dejan NULL. NO agrega soft delete (respeta ADR-DB-004).
  // La política D2 (reemplazo) se ejecuta por hard delete filtrado por este campo.
  aiRecommendationId String? @map("ai_recommendation_id") @db.Uuid

  // Única excepción a onDelete: Restrict — composición pura (AC-08).
  budget           Budget            @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  aiRecommendation AIRecommendation? @relation("BudgetItemAIRecommendation", fields: [aiRecommendationId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean  @default(false) @map("is_seed")

  @@index([budgetId])
  @@index([aiRecommendationId])
  @@map("budget_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// Quote
// ─────────────────────────────────────────────────────────────────────────────

model QuoteRequest {
  id                 String             @id @default(uuid()) @db.Uuid
  eventId            String             @map("event_id") @db.Uuid
  serviceCategoryId  String             @map("service_category_id") @db.Uuid
  // US-102: quote request opcionalmente dirigida a un vendor; soporte para
  // uq_quote_requests_event_vendor_active (C-027, unique parcial por estado activo).
  vendorProfileId    String?            @map("vendor_profile_id") @db.Uuid
  status             QuoteRequestStatus @default(sent)
  aiBriefMeta        Json?              @map("ai_brief_meta") @db.JsonB
  // US-096 (PB-P0-004): brief provisto por el organizer (summary/requirements/questions/constraints)
  // como JSONB; timestamps de lifecycle; referencia opcional a AIRecommendation (sin FK formal).
  brief              Json?              @db.JsonB
  viewedAt           DateTime?          @map("viewed_at") @db.Timestamptz(6)
  cancelledAt        DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  aiRecommendationId String?            @map("ai_recommendation_id") @db.Uuid

  event           Event           @relation(fields: [eventId], references: [id], onDelete: Restrict)
  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Restrict)
  vendorProfile   VendorProfile?  @relation(fields: [vendorProfileId], references: [id], onDelete: Restrict)

  quotes            Quote[]
  aiRecommendations AIRecommendation[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean  @default(false) @map("is_seed")

  @@index([eventId])
  @@index([serviceCategoryId])
  @@index([vendorProfileId])
  @@map("quote_requests")
}

model Quote {
  id              String       @id @default(uuid()) @db.Uuid
  quoteRequestId  String       @map("quote_request_id") @db.Uuid
  vendorProfileId String       @map("vendor_profile_id") @db.Uuid
  amount          Decimal      @db.Decimal(14, 2)
  currency        CurrencyCode @default(GTQ)
  validUntil      DateTime?    @map("valid_until") @db.Timestamptz(6)
  status          QuoteStatus  @default(draft)
  // US-096 (PB-P0-004): desglose (breakdown JSONB) + condiciones + preferencia + timestamps de
  // lifecycle. `amount` mapea a `totalPrice` del contrato API; `currency` a `currencyCode`.
  breakdown       Json?        @db.JsonB
  conditions      String?
  isPreferred     Boolean      @default(false) @map("is_preferred")
  sentAt          DateTime?    @map("sent_at") @db.Timestamptz(6)
  acceptedAt      DateTime?    @map("accepted_at") @db.Timestamptz(6)
  rejectedAt      DateTime?    @map("rejected_at") @db.Timestamptz(6)
  expiredAt       DateTime?    @map("expired_at") @db.Timestamptz(6)

  quoteRequest  QuoteRequest  @relation(fields: [quoteRequestId], references: [id], onDelete: Restrict)
  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Restrict)

  bookingIntents BookingIntent[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean  @default(false) @map("is_seed")

  @@index([quoteRequestId])
  @@index([vendorProfileId])
  @@map("quotes")
}

model BookingIntent {
  id                 String              @id @default(uuid()) @db.Uuid
  quoteId            String              @map("quote_id") @db.Uuid
  // US-102: (event, category) para uq_booking_intents_event_category_confirmed (C-037).
  eventId            String              @map("event_id") @db.Uuid
  serviceCategoryId  String              @map("service_category_id") @db.Uuid
  status             BookingIntentStatus @default(pending)
  // US-102: chk_booking_intents_is_simulated (C-038; MVP no procesa pagos reales).
  isSimulated        Boolean             @default(true) @map("is_simulated")
  confirmedAt        DateTime?           @map("confirmed_at") @db.Timestamptz(6)
  // US-096 (PB-P0-004): vendor asignado (denormalizado desde el quote para auth/consultas) y
  // metadatos de cancelación (razón obligatoria — VR-10).
  vendorProfileId    String?             @map("vendor_profile_id") @db.Uuid
  cancelledAt        DateTime?           @map("cancelled_at") @db.Timestamptz(6)
  cancelledBy        String?             @map("cancelled_by") @db.Uuid
  cancellationReason String?             @map("cancellation_reason")
  // US-039 (PB-P1-023 / D1): idempotencia del sync de `BudgetItem.committed`. Ambos NULL cuando
  // el intent no está sincronizado; `committedSyncedAmount` preserva el monto original para una
  // reversa exacta independiente de cambios posteriores en `Quote.amount`.
  committedSyncedAt     DateTime? @map("committed_synced_at") @db.Timestamptz(6)
  committedSyncedAmount Decimal?  @map("committed_synced_amount") @db.Decimal(14, 2)

  quote           Quote           @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  event           Event           @relation(fields: [eventId], references: [id], onDelete: Restrict)
  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Restrict)
  vendorProfile   VendorProfile?  @relation(fields: [vendorProfileId], references: [id], onDelete: Restrict)
  reviews         Review[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean  @default(false) @map("is_seed")

  @@index([quoteId])
  @@index([eventId])
  @@index([serviceCategoryId])
  @@index([vendorProfileId])
  @@map("booking_intents")
}

// ─────────────────────────────────────────────────────────────────────────────
// Transversales
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id              String       @id @default(uuid()) @db.Uuid
  bookingIntentId String       @map("booking_intent_id") @db.Uuid
  vendorProfileId String       @map("vendor_profile_id") @db.Uuid
  authorId        String       @map("author_id") @db.Uuid
  rating          Int
  comment         String?
  status          ReviewStatus @default(published)

  bookingIntent BookingIntent @relation(fields: [bookingIntentId], references: [id], onDelete: Restrict)
  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Restrict)
  author        User          @relation(fields: [authorId], references: [id], onDelete: Restrict)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean   @default(false) @map("is_seed")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([vendorProfileId])
  @@index([bookingIntentId])
  @@index([authorId])
  @@map("reviews")
}

model Notification {
  id      String             @id @default(uuid()) @db.Uuid
  userId  String             @map("user_id") @db.Uuid
  type    String
  payload Json               @db.JsonB
  status  NotificationStatus @default(unread)
  readAt  DateTime?          @map("read_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean  @default(false) @map("is_seed")

  @@index([userId])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// Admin / AI
// ─────────────────────────────────────────────────────────────────────────────

model AdminAction {
  id           String @id @default(uuid()) @db.Uuid
  adminUserId  String @map("admin_user_id") @db.Uuid
  action       String
  targetEntity String @map("target_entity")
  targetId     String @map("target_id") @db.Uuid
  metadata     Json?  @db.JsonB

  adminUser User @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean  @default(false) @map("is_seed")

  @@index([adminUserId])
  @@map("admin_actions")
}

model AIRecommendation {
  id                String                 @id @default(uuid()) @db.Uuid
  // US-097 (PB-P0-004): `event_id` pasa a nullable — vendor_bio no tiene evento. `ai_prompt_version_id`
  // permanece requerido (invariante US-099); US-097 usa un AIPromptVersion placeholder hasta PB-P0-010.
  eventId           String?                @map("event_id") @db.Uuid
  aiPromptVersionId String                 @map("ai_prompt_version_id") @db.Uuid
  requestedByUserId String                 @map("requested_by_user_id") @db.Uuid
  vendorProfileId   String?                @map("vendor_profile_id") @db.Uuid
  quoteRequestId    String?                @map("quote_request_id") @db.Uuid
  kind              String
  inputPayload      Json                   @map("input_payload") @db.JsonB
  outputPayload     Json                   @map("output_payload") @db.JsonB
  // US-097: metadatos del provider (provider/promptVersion/latencyMs/fallbackUsed/languageCode).
  aiMeta            Json?                  @map("ai_meta") @db.JsonB
  status            AIRecommendationStatus @default(pending)
  // expires_at: expiración de la recomendación para índice parcial idx_ai_rec_pending_expires
  // (US-101 / Doc 18 §25; job de expiración de AIRecommendation).
  expiresAt         DateTime?              @map("expires_at") @db.Timestamptz(6)
  // US-102: chk_ai_recommendations_timeout_positive (>0) y chk_ai_recommendations_retry_max (0..1) — Doc 18 §21.1.
  timeoutMs         Int                    @default(60000) @map("timeout_ms")
  retryCount        Int                    @default(0) @map("retry_count")

  event         Event?          @relation(fields: [eventId], references: [id], onDelete: Restrict)
  promptVersion AIPromptVersion @relation(fields: [aiPromptVersionId], references: [id], onDelete: Restrict)
  requestedBy   User            @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)
  vendorProfile VendorProfile?  @relation(fields: [vendorProfileId], references: [id], onDelete: Restrict)
  quoteRequest  QuoteRequest?   @relation(fields: [quoteRequestId], references: [id], onDelete: Restrict)
  // US-031 (PB-P1-017): relación inversa con `event_tasks.ai_recommendation_id`.
  eventTasks    EventTask[]     @relation("EventTaskAIRecommendation")
  // US-037 (PB-P1-021): relación inversa con `budget_items.ai_recommendation_id`.
  budgetItems   BudgetItem[]    @relation("BudgetItemAIRecommendation")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isSeed    Boolean  @default(false) @map("is_seed")

  @@index([eventId])
  @@index([aiPromptVersionId])
  @@index([requestedByUserId])
  @@index([vendorProfileId])
  @@index([quoteRequestId])
  @@map("ai_recommendations")
}

// Append-only conceptual (enforcement técnico -> US-102). No declara isSeed ni deletedAt.
model AIPromptVersion {
  id               String                @id @default(uuid()) @db.Uuid
  // US-102: prompt_id agrupa versiones del mismo prompt lógico; status habilita
  // uq_prompt_versions_active (una versión activa por prompt — Doc 18 §21.2).
  promptId         String                @map("prompt_id") @db.Uuid
  promptKey        String                @map("prompt_key")
  version          String
  status           AIPromptVersionStatus @default(active)
  provider         LLMProvider
  templateChecksum String                @map("template_checksum")
  description      String?

  recommendations AIRecommendation[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([promptKey, version])
  @@index([promptId])
  @@map("ai_prompt_versions")
}
