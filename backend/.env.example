# EventFlow backend — variables de entorno (ejemplo). US-089 / OPS-001.
# NUNCA commitear valores reales ni secretos (SEC-01, SEC-02, ADR-SEC-005, NFR-SEC-008).
# Copiar a `.env` (gitignored) y completar con valores locales. Categorías per Doc 14 §27.

# ── APP ────────────────────────────────────────────────────────────────────
# PORT: entero positivo. NODE_ENV: development | test | production.
PORT=3000
NODE_ENV=development

# ── DATABASE ───────────────────────────────────────────────────────────────
# DATABASE_URL: URL de conexión PostgreSQL (formato de ejemplo, sin credenciales reales).
DATABASE_URL="postgresql://user:password@localhost:5432/eventflow?schema=public"

# ── AUTH ───────────────────────────────────────────────────────────────────
# JWT_SECRET: mínimo 32 caracteres. JWT_EXPIRES_IN: p. ej. 7d, 12h.
JWT_SECRET="your_jwt_secret_min_32_chars_placeholder"
JWT_EXPIRES_IN=7d

# ── SESSION (US-094 / PB-P0-004 — ADR-SEC-002 cookie HTTP-only firmada) ──────
# SESSION_SECRET: mínimo 32 caracteres, rotable. Firma la cookie de sesión (cookie-parser).
# SESSION_COOKIE_NAME: nombre de la cookie (default eventflow_session).
# SESSION_TTL_HOURS: vigencia de la sesión (default 168 = 7 días).
# SESSION_COOKIE_SECURE: fuerza `Secure`; si se omite se deriva de NODE_ENV (Secure en producción).
# RESET_TOKEN_TTL_MINUTES: TTL del token de reset de contraseña (default 15).
# BCRYPT_SALT_ROUNDS: coste de bcrypt para el hash de contraseñas (default 12).
SESSION_SECRET="your_session_secret_min_32_chars_placeholder"
SESSION_COOKIE_NAME=eventflow_session
SESSION_TTL_HOURS=168
SESSION_COOKIE_SECURE=false
RESET_TOKEN_TTL_MINUTES=15
BCRYPT_SALT_ROUNDS=12

# ── AI ─────────────────────────────────────────────────────────────────────
# LLM_PROVIDER: openai | mock | anthropic. OPENAI_API_KEY: opcional (solo si provider=openai).
LLM_PROVIDER=mock
OPENAI_API_KEY=

# ── SECURITY ───────────────────────────────────────────────────────────────
# CORS_ORIGINS: lista separada por comas. CAPTCHA_PROVIDER: recaptcha | mock.
# HELMET_ENABLED: true por defecto. RATE_LIMIT_*: ventana y máximo de requests (global laxo).
# AUTH_RATE_LIMIT_MAX: máximo estricto para /auth/* (US-091; aplicado en feature stories).
# FILE_SIZE_LIMIT: tamaño máximo de upload en bytes (5242880 = 5 MB).
CORS_ORIGINS="http://localhost:3000"
CAPTCHA_PROVIDER=mock
CAPTCHA_SECRET=your_captcha_secret_here
HELMET_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
JSON_BODY_LIMIT=1mb
FILE_SIZE_LIMIT=5242880

# ── LOGGING ────────────────────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warn | error.
LOG_LEVEL=info

# ── SEED ───────────────────────────────────────────────────────────────────
# SEED_ENABLED: habilita la carga de datos de demo (false por defecto).
SEED_ENABLED=false

# ── AI (US-097 / PB-P0-004) ─────────────────────────────────────────────────
# AI_TIMEOUT_MS: timeout del LLMProvider en ms. AI_DEMO_MODE: habilita fallback a mock.
# AI_RATE_LIMIT_MAX: máximo de requests de generación AI por usuario/ventana.
AI_TIMEOUT_MS=8000
AI_DEMO_MODE=false
AI_RATE_LIMIT_MAX=30
