# EventFlow backend — variables de entorno (ejemplo). US-089 / OPS-001.
# NUNCA commitear valores reales ni secretos (SEC-01, SEC-02, ADR-SEC-005, NFR-SEC-008).
# Copiar a `.env` (gitignored) y completar con valores locales. Categorías per Doc 14 §27.

# ── APP ────────────────────────────────────────────────────────────────────
# PORT: entero positivo. NODE_ENV: development | test | production.
PORT=3000
NODE_ENV=development

# ── DATABASE ───────────────────────────────────────────────────────────────
# DATABASE_URL: URL de conexión PostgreSQL (formato de ejemplo, sin credenciales reales).
DATABASE_URL="postgresql://user:password@localhost:5432/eventflow?schema=public"

# ── AUTH ───────────────────────────────────────────────────────────────────
# JWT_SECRET: mínimo 32 caracteres. JWT_EXPIRES_IN: p. ej. 7d, 12h.
JWT_SECRET="your_jwt_secret_min_32_chars_placeholder"
JWT_EXPIRES_IN=7d

# ── SESSION (US-094 / PB-P0-004; US-108 / PB-P0-006 — ADR-SEC-002 cookie HTTP-only firmada) ──
# SESSION_SECRET: mínimo 32 caracteres, rotable. Firma la cookie de sesión (cookie-parser).
# SESSION_COOKIE_NAME: nombre de la cookie (default eventflow_session; override documentado US-108).
# SESSION_COOKIE_MAX_AGE_DAYS: vigencia de sesión/cookie en días (default 30 — decisión PB-P0-006).
# SESSION_COOKIE_SECURE: fuerza `Secure`; si se omite se deriva de NODE_ENV (Secure en producción).
#   OBLIGATORIO true en QA/Demo/producción (NODE_ENV=production); false solo en Local/CI (HTTP).
# SESSION_COOKIE_SAMESITE: lax | none | strict (default lax). `none` exige Secure=true + CORS
#   credentials + allowlist (cross-site Amplify ↔ App Runner). El boot falla si es inseguro.
# RESET_TOKEN_TTL_MINUTES: TTL del token de reset (default 30 — US-004 Decisión PO #4, override Doc 19 §11).
# BCRYPT_SALT_ROUNDS: coste de bcrypt para el hash de contraseñas (default 12).
SESSION_SECRET="your_session_secret_min_32_chars_placeholder"
SESSION_COOKIE_NAME=eventflow_session
SESSION_COOKIE_MAX_AGE_DAYS=30
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
RESET_TOKEN_TTL_MINUTES=30
BCRYPT_SALT_ROUNDS=12

# ── AI ─────────────────────────────────────────────────────────────────────
# LLM_PROVIDER: openai | mock | anthropic. Config OpenAI (US-118) es backend-only y sólo se
# requiere cuando LLM_PROVIDER=openai; CI/tests usan `mock` y NO necesitan secretos reales (AC-08).
# OPENAI_API_KEY / OPENAI_MODEL: requeridos si provider=openai. OPENAI_BASE_URL: opcional (default
# https://api.openai.com/v1). Nunca exponer estas variables al frontend.
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# ── SECURITY ───────────────────────────────────────────────────────────────
# CORS_ORIGINS: allowlist explícita separada por comas (nunca "*" con credenciales).
# CORS_CREDENTIALS: envío de cookies cross-origin (default true; requerido true si SameSite=None).
# CAPTCHA_PROVIDER: mock | recaptcha | hcaptcha (US-109). `mock` sólo Local/CI (falla en producción).
#   El único token válido en mock es '__test__'. QA/Demo/prod usan proveedor real.
# CAPTCHA_SECRET: legacy genérico (US-091); los providers reales usan las vars específicas de abajo.
# RECAPTCHA_SECRET_KEY / HCAPTCHA_SECRET_KEY: secreto backend del proveedor real (requerido según
#   CAPTCHA_PROVIDER). SÓLO backend/Secrets Manager; nunca NEXT_PUBLIC_* ni committeado.
# CAPTCHA_SCORE_THRESHOLD: umbral reCAPTCHA v3 (0..1, default 0.5). CAPTCHA_VERIFY_TIMEOUT_MS: timeout ms.
# HELMET_ENABLED: true por defecto. RATE_LIMIT_*: ventana y máximo de requests (global laxo).
# AUTH_RATE_LIMIT_MAX: máximo estricto para /auth/* (US-091; aplicado en feature stories).
# FILE_SIZE_LIMIT: tamaño máximo de upload en bytes (5242880 = 5 MB).
CORS_ORIGINS="http://localhost:3000"
CORS_CREDENTIALS=true
CAPTCHA_PROVIDER=mock
CAPTCHA_SECRET=your_captcha_secret_here
RECAPTCHA_SECRET_KEY=
HCAPTCHA_SECRET_KEY=
CAPTCHA_SCORE_THRESHOLD=0.5
CAPTCHA_VERIFY_TIMEOUT_MS=3000
HELMET_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
JSON_BODY_LIMIT=1mb
FILE_SIZE_LIMIT=5242880

# ── RATE LIMITING estricto (US-110 / PB-P0-007 — ADR-SEC-004) ────────────────
# Enteros positivos (fail-fast en boot). Defaults MVP = contrato de QA/Demo (no desactivar en Demo).
# login: 10/IP/10min · register: 5/IP/10min · password reset: 3/email normalizado/1h · IA: 10/user/1h.
# RATE_LIMIT_ENABLED: interruptor de enforcement (default true). El setup de tests lo pone en false.
# Local/CI pueden reducir max/window para tests determinísticos SIN desactivar el control.
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=600000
AUTH_REGISTER_RATE_LIMIT_MAX=5
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=600000
AUTH_PASSWORD_RESET_RATE_LIMIT_MAX=3
AUTH_PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_ENABLED=true
# Captcha CONDICIONAL en /auth/login (US-003 / PB-P1-003 — Decisión PO #1/#2): se exige captcha
# a partir de AUTH_LOGIN_CAPTCHA_THRESHOLD fallos consecutivos por IP+email dentro de la ventana.
AUTH_LOGIN_CAPTCHA_THRESHOLD=3
AUTH_LOGIN_ATTEMPT_WINDOW_MS=600000
# Rate limit del confirm de reset /auth/password/reset (US-004: 5/IP/10min — Doc 19 §6).
AUTH_PASSWORD_RESET_CONFIRM_RATE_LIMIT_MAX=5
AUTH_PASSWORD_RESET_CONFIRM_RATE_LIMIT_WINDOW_MS=600000

# ── LOGGING ────────────────────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warn | error.
LOG_LEVEL=info

# ── SEED ───────────────────────────────────────────────────────────────────
# SEED_ENABLED: habilita la carga de datos de demo (false por defecto).
SEED_ENABLED=false
# SEED_DEMO_ENABLED (US-086 / PB-P0-014): flag operativo del reset surgical Demo. Gate del endpoint
# POST /api/v1/admin/seed/reset — con flag off la ruta NO se registra (404). false por defecto;
# true sólo en dev/qa/demo, NUNCA en production (Doc 14 §15.2 SEED, THR-012).
SEED_DEMO_ENABLED=false
# SEED_BATCH_SIZE (US-086): tamaño de lote de los deletes surgicales del reset ($transaction chunked).
SEED_BATCH_SIZE=1000

# ── AI (US-097 / PB-P0-004; US-110 / PB-P0-007; US-123 / PB-P0-011) ─────────
# AI_TIMEOUT_MS: timeout del LLMProvider en ms. Default oficial 60000 (US-123 / PO 8.1 #9, BR-AI-009).
# AI_DEMO_MODE: modo demo; habilita fallback a MockAIProvider. Prohibido en NODE_ENV=production.
# AI_USE_MOCK_FALLBACK: habilita fallback a MockAIProvider fuera de demo. Prohibido en production.
# AI_LOG_PAYLOADS: logging de payloads AI. Prohibido en demo (AI_DEMO_MODE) y production (SEC-04).
# AI_RATE_LIMIT_MAX / AI_RATE_LIMIT_WINDOW_MS: cuota agregada de generación IA por usuario
#   autenticado (key ai:user:{userId}). Default MVP US-110: 10 generaciones por 1 h.
# Matriz de environments (US-123):
#   test:               LLM_PROVIDER=mock, AI_DEMO_MODE=false, AI_USE_MOCK_FALLBACK=false, sin red.
#   demo-academic:      LLM_PROVIDER=openai, AI_DEMO_MODE=true, AI_USE_MOCK_FALLBACK=true, AI_LOG_PAYLOADS=false.
#   production-academic: AI_DEMO_MODE=false, AI_USE_MOCK_FALLBACK=false, AI_LOG_PAYLOADS=false (sin fallback silencioso).
AI_TIMEOUT_MS=60000
AI_DEMO_MODE=false
AI_USE_MOCK_FALLBACK=false
AI_LOG_PAYLOADS=false
AI_RATE_LIMIT_MAX=10
AI_RATE_LIMIT_WINDOW_MS=3600000

# ── JOBS (US-015 / PB-P1-009 — ADR-BE-004 Simple Scheduled Jobs) ────────────
# JOBS_ENABLED: habilita el registro de schedulers intra-proceso. Debe estar en `true` en
# EXACTAMENTE UNA réplica del backend para evitar duplicación en multi-instancia (EC-03).
# Default `false` en dev/test/QA y en réplicas no-primarias (SEC-01..04).
JOBS_ENABLED=false
# JOBS_AUTOCOMPLETE_CRON: cadencia del `AutoCompletePastEventsJob`. Default `30 0 * * *`
# (00:30 UTC diario, decisión PO 8.1 #6). `docs/14` ofrece `0 * * * *` como opción horaria.
# Parámetro operativo, no funcional: cambia sin afectar la corrección del cierre T+2.
JOBS_AUTOCOMPLETE_CRON=30 0 * * *
# JOBS_EXPIRE_QUOTES_CRON: cadencia del `ExpireQuotesJob` (US-053). Default `5 0 * * *`
# (00:05 UTC diario). Marca `Quote.status='sent' AND valid_until < CURRENT_DATE` a `expired`
# con batches SKIP LOCKED y 2 notifications por Quote al vendor asignado (BR-QUOTE-005).
JOBS_EXPIRE_QUOTES_CRON=5 0 * * *
# JOBS_EXPIRE_QUOTES_JITTER_MAX_MS: jitter random `[0..N]` ms antes de invocar el use case.
# Default 600000 (10 min). Evita sincronización de réplicas del scheduler. Pon 0 para tests.
JOBS_EXPIRE_QUOTES_JITTER_MAX_MS=600000
# JOBS_EXPIRE_QUOTES_BATCH_SIZE: tamaño del batch `LIMIT ? FOR UPDATE SKIP LOCKED`. Default 100.
JOBS_EXPIRE_QUOTES_BATCH_SIZE=100

# ── FILE STORAGE (US-043 / PB-P1-026 — portafolio del vendor) ─────────────
# `FILE_STORAGE_DRIVER`: adapter concreto usado por `FileStoragePort`. En MVP sólo `local`.
# `FILE_STORAGE_PATH`: raíz donde el `LocalFileStorageAdapter` escribe `<yyyy>/<mm>/<uuid>.<ext>`.
# La ruta DEBE estar FUERA del web root del backend/frontend (SEC-03) — jamás la sirvas via static.
# El directorio se crea de forma idempotente (`mkdir recursive`) en el primer `save()`.
FILE_STORAGE_DRIVER=local
FILE_STORAGE_PATH=./storage/uploads
