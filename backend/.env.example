# EventFlow backend — variables de entorno (ejemplo). US-089 / OPS-001.
# NUNCA commitear valores reales ni secretos (SEC-01, SEC-02, ADR-SEC-005, NFR-SEC-008).
# Copiar a `.env` (gitignored) y completar con valores locales. Categorías per Doc 14 §27.

# ── APP ────────────────────────────────────────────────────────────────────
# PORT: entero positivo. NODE_ENV: development | test | production.
PORT=3000
NODE_ENV=development

# ── DATABASE ───────────────────────────────────────────────────────────────
# DATABASE_URL: URL de conexión PostgreSQL (formato de ejemplo, sin credenciales reales).
DATABASE_URL="postgresql://user:password@localhost:5432/eventflow?schema=public"

# ── AUTH ───────────────────────────────────────────────────────────────────
# JWT_SECRET: mínimo 32 caracteres. JWT_EXPIRES_IN: p. ej. 7d, 12h.
JWT_SECRET="your_jwt_secret_min_32_chars_placeholder"
JWT_EXPIRES_IN=7d

# ── SESSION (US-094 / PB-P0-004; US-108 / PB-P0-006 — ADR-SEC-002 cookie HTTP-only firmada) ──
# SESSION_SECRET: mínimo 32 caracteres, rotable. Firma la cookie de sesión (cookie-parser).
# SESSION_COOKIE_NAME: nombre de la cookie (default eventflow_session; override documentado US-108).
# SESSION_COOKIE_MAX_AGE_DAYS: vigencia de sesión/cookie en días (default 30 — decisión PB-P0-006).
# SESSION_COOKIE_SECURE: fuerza `Secure`; si se omite se deriva de NODE_ENV (Secure en producción).
#   OBLIGATORIO true en QA/Demo/producción (NODE_ENV=production); false solo en Local/CI (HTTP).
# SESSION_COOKIE_SAMESITE: lax | none | strict (default lax). `none` exige Secure=true + CORS
#   credentials + allowlist (cross-site Amplify ↔ App Runner). El boot falla si es inseguro.
# RESET_TOKEN_TTL_MINUTES: TTL del token de reset de contraseña (default 15).
# BCRYPT_SALT_ROUNDS: coste de bcrypt para el hash de contraseñas (default 12).
SESSION_SECRET="your_session_secret_min_32_chars_placeholder"
SESSION_COOKIE_NAME=eventflow_session
SESSION_COOKIE_MAX_AGE_DAYS=30
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
RESET_TOKEN_TTL_MINUTES=15
BCRYPT_SALT_ROUNDS=12

# ── AI ─────────────────────────────────────────────────────────────────────
# LLM_PROVIDER: openai | mock | anthropic. OPENAI_API_KEY: opcional (solo si provider=openai).
LLM_PROVIDER=mock
OPENAI_API_KEY=

# ── SECURITY ───────────────────────────────────────────────────────────────
# CORS_ORIGINS: allowlist explícita separada por comas (nunca "*" con credenciales).
# CORS_CREDENTIALS: envío de cookies cross-origin (default true; requerido true si SameSite=None).
# CAPTCHA_PROVIDER: mock | recaptcha | hcaptcha (US-109). `mock` sólo Local/CI (falla en producción).
#   El único token válido en mock es '__test__'. QA/Demo/prod usan proveedor real.
# CAPTCHA_SECRET: legacy genérico (US-091); los providers reales usan las vars específicas de abajo.
# RECAPTCHA_SECRET_KEY / HCAPTCHA_SECRET_KEY: secreto backend del proveedor real (requerido según
#   CAPTCHA_PROVIDER). SÓLO backend/Secrets Manager; nunca NEXT_PUBLIC_* ni committeado.
# CAPTCHA_SCORE_THRESHOLD: umbral reCAPTCHA v3 (0..1, default 0.5). CAPTCHA_VERIFY_TIMEOUT_MS: timeout ms.
# HELMET_ENABLED: true por defecto. RATE_LIMIT_*: ventana y máximo de requests (global laxo).
# AUTH_RATE_LIMIT_MAX: máximo estricto para /auth/* (US-091; aplicado en feature stories).
# FILE_SIZE_LIMIT: tamaño máximo de upload en bytes (5242880 = 5 MB).
CORS_ORIGINS="http://localhost:3000"
CORS_CREDENTIALS=true
CAPTCHA_PROVIDER=mock
CAPTCHA_SECRET=your_captcha_secret_here
RECAPTCHA_SECRET_KEY=
HCAPTCHA_SECRET_KEY=
CAPTCHA_SCORE_THRESHOLD=0.5
CAPTCHA_VERIFY_TIMEOUT_MS=3000
HELMET_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
JSON_BODY_LIMIT=1mb
FILE_SIZE_LIMIT=5242880

# ── LOGGING ────────────────────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warn | error.
LOG_LEVEL=info

# ── SEED ───────────────────────────────────────────────────────────────────
# SEED_ENABLED: habilita la carga de datos de demo (false por defecto).
SEED_ENABLED=false

# ── AI (US-097 / PB-P0-004) ─────────────────────────────────────────────────
# AI_TIMEOUT_MS: timeout del LLMProvider en ms. AI_DEMO_MODE: habilita fallback a mock.
# AI_RATE_LIMIT_MAX: máximo de requests de generación AI por usuario/ventana.
AI_TIMEOUT_MS=8000
AI_DEMO_MODE=false
AI_RATE_LIMIT_MAX=30
